# =============================================================================
# PetCard Mobile — variáveis de ambiente
# =============================================================================
# Copie este arquivo para `.env` e preencha com os valores do seu ambiente.
# O `.env` está no .gitignore — nunca faça commit dele.
#
# Observação sobre Expo:
# Apenas variáveis com prefixo EXPO_PUBLIC_ são embutidas no bundle do
# cliente e ficam acessíveis via `process.env`. Variáveis sem o prefixo
# só estão disponíveis em tempo de build / scripts.
# Ref.: https://docs.expo.dev/guides/environment-variables/
# =============================================================================


# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# URL base usada pelo cliente Axios (src/services/api.ts).
# - Local:        http://localhost:3000
# - Codespaces:   https://<codespace>-3000.app.github.dev
# - Túnel/ngrok:  https://<subdominio>.ngrok-free.app
EXPO_PUBLIC_API_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------
# API Key do Google Cloud com Maps SDK for Android e Maps SDK for iOS habilitados.
# Usada pelo react-native-maps para renderizar o mapa com provider Google.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
